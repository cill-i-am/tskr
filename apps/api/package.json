{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "git -C ../.. ls-files -- apps/api | xargs pnpm --dir ../.. exec ultracite check",
    "db:ensure": "node ../../scripts/local-postgres.mjs ensure",
    "dev": "portless run --name api.tskr node ../../scripts/local-postgres-launcher.mjs -- tsx watch src/index.ts",
    "dev:sandbox": "PORTLESS=0 PORT=3001 tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run --globals src/app.test.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@workspace/db": "workspace:*",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}

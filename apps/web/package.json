{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "git -C ../.. ls-files -- apps/web ':(exclude)apps/web/public/favicon.ico' | xargs pnpm --dir ../.. exec ultracite check",
    "dev": "portless --name web.tskr vite dev",
    "build": "pnpm --filter @workspace/ui build && vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "test": "pnpm --filter @workspace/ui build && vitest run",
    "typecheck": "pnpm --filter @workspace/ui build && tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.5.5",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "nitro": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["pnpm-workspace.yaml"],
  "tasks": {
    "check": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_ROOT$/.oxfmtrc.jsonc"
      ]
    },
    "//#fix": {
      "cache": false
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "web#build": {
      "dependsOn": ["transit"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.json", ".env*"],
      "outputs": [".output/**", "node_modules/.nitro/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

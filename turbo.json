{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["pnpm-workspace.yaml"],
  "globalPassThroughEnv": [
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_TRUSTED_ORIGINS",
    "BETTER_AUTH_URL",
    "DATABASE_URL",
    "E2E_EMAIL_CAPTURE_DIR",
    "EMAIL_FROM",
    "EMAIL_PROVIDER",
    "NODE_TLS_REJECT_UNAUTHORIZED",
    "NODE_ENV",
    "PORT",
    "PORTLESS",
    "VITE_AUTH_BASE_URL",
    "WEB_BASE_URL"
  ],
  "tasks": {
    "check": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_ROOT$/.oxfmtrc.jsonc"
      ]
    },
    "//#fix": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.json", ".env*"],
      "outputs": ["dist/**", ".output/**", "node_modules/.nitro/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.json"]
    },
    "dev": {
      "cache": false
    },
    "dev:sandbox": {
      "cache": false
    },
    "db:ensure": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "e2e:dev": {
      "cache": false,
      "dependsOn": ["^build"],
      "persistent": true
    },
    "web#dev": {
      "cache": false,
      "persistent": true,
      "with": ["@workspace/ui#dev"]
    },
    "web#dev:sandbox": {
      "cache": false,
      "persistent": true,
      "with": ["@workspace/ui#dev"]
    },
    "api#dev:sandbox": {
      "cache": false,
      "persistent": true,
      "with": ["@workspace/db#dev"]
    },
    "auth#dev": {
      "cache": false,
      "persistent": true,
      "with": ["@workspace/email#dev"]
    },
    "auth#dev:sandbox": {
      "cache": false,
      "persistent": true,
      "with": ["@workspace/db#dev", "@workspace/email#dev"]
    }
  }
}

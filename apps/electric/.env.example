# Postgres settings for the standalone local scaffold in compose.yaml.
POSTGRES_DB=electric
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=54321

# Optional: set a unique Compose project name when running multiple worktrees.
# COMPOSE_PROJECT_NAME=tskr-electric-cillian-local

# Electric runs as a separate service in front of Postgres.
# The Postgres instance must have logical replication enabled.
DATABASE_URL=postgresql://postgres:password@postgres:5432/electric?sslmode=disable
ELECTRIC_PORT=3000
ELECTRIC_STORAGE_DIR=/var/lib/electric/persistent

# Development only. For production, remove this and set ELECTRIC_SECRET instead.
ELECTRIC_INSECURE=true

# Production example:
# ELECTRIC_SECRET=replace-with-a-long-random-secret

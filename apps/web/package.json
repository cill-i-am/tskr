{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "git -C ../.. ls-files -- apps/web ':(exclude)apps/web/public/favicon.ico' | xargs pnpm --dir ../.. exec ultracite check",
    "dev": "portless run --name web.tskr vite dev",
    "dev:sandbox": "PORTLESS=0 vite dev --host 0.0.0.0 --port 3000",
    "e2e:dev": "portless run --name e2e-web.tskr --app-port 4791 --force vite dev",
    "build": "pnpm --filter @workspace/ui build && vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "test": "pnpm --filter @workspace/ui build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/client": "^1.5.14",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/electric-db-collection": "^0.2.43",
    "@tanstack/react-db": "^0.1.79",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@workspace/sync-contracts": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.5.5",
    "effect": "^3.21.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@workspace/db": "workspace:*",
    "jsdom": "^29.0.0",
    "nitro": "^3.0.260311-beta",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0"
  }
}
